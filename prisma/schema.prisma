// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RoleEnum {
ADMIN
USER
}

enum CategoryEnum {
MATCH
PLAYER
TRANSFER
NEWS
FANS
HISTORY
TRAINING
EVENT
MERCH
}

model Blog {
  id String @id @default(uuid())
  title String @unique
  slug String @unique
  excerpt String
  content String
  authorName String
  category CategoryEnum @default(NEWS)
  ceatedAt DateTime @default(now())
  updatedAt DateTime?
}

model User {
  id String @id @default(uuid())
  email String @unique
  password String
  firstName String
  lastName String
  avatar String?
  role RoleEnum @default(USER)
  createdAt DateTime @default(now())
  deletedAt DateTime?
}

model EmailForm {
  id String @id @default(uuid())
  email String
  message String
  createdAt DateTime @default(now())
}